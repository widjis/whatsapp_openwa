# Server
PORT=8192
ALLOWED_IPS=127.0.0.1,::1
ALLOWED_PHONE_NUMBERS=
DATA_DIR=data

# OpenWA
OPENWA_BASE_URL=http://10.60.10.59:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=
OPENWA_SESSION_NAME=

# Optional webhook protection
OPENWA_WEBHOOK_SECRET=
OPENWA_WEBHOOK_URL=

# Optional SRF approval mentions (comma-separated phone numbers or JIDs; will be normalized to @c.us)
SRF_APPROVER_PHONES=

# Optional SRF detection via AI (fallback to heuristic when disabled or OPENAI_API_KEY missing)
SRF_DETECTION_AI_ENABLED=true
SRF_DETECTION_AI_MODEL=gpt-4o-mini

# Optional inbound polling (fallback when OpenWA webhooks cannot call internal URLs)
OPENWA_POLLING_ENABLED=false
OPENWA_POLLING_INTERVAL_MS=1500
OPENWA_POLLING_LIMIT=50
OPENWA_POLLING_CHAT_ID=

# Optional LAPS admin whitelist (fallback to ALLOWED_PHONE_NUMBERS)
LAPS_ADMIN_PHONE_NUMBERS=

# n8n integration (inbound non-command -> webhook -> auto-reply)
N8N_WEBHOOK_URL=
N8N_ENABLED=false
N8N_TIMEOUT=60000
N8N_API_KEY=
N8N_DEBUG=false
N8N_FALLBACK_ENABLED=true
N8N_FALLBACK_TEXT="AI system not available. Please try again later."

# Dispatcher leave schedule filtering
# First N people in the sheet are Superintendent, next M are Supervisor (including VACANT slots).
DISPATCHER_LEAVE_SCHEDULE_ENABLED=false
DISPATCHER_LEAVE_SCHEDULE_SUPERINTENDENT_COUNT=0
DISPATCHER_LEAVE_SCHEDULE_SUPERVISOR_COUNT=0
